{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "hpp_dyad_transmission_summary",
  "title": "HPP Table C — per-dyad transmission summary",
  "description": "SPEC_HPP.md §4.C. Per-dyad rollup; replaces any 'family_transmission_summary' table — family hubs are NOT a unit of aggregation. Dyads have only partial Mendelian coverage (parent-hom sites).",
  "type": "object",
  "required": ["format", "columns", "types"],
  "properties": {
    "format": {"const": "tsv"},
    "columns": {
      "type": "array",
      "items": {
        "enum": [
          "dyad_id",
          "parent_sample_id",
          "offspring_sample_id",
          "n_segments_total",
          "n_segments_Gold",
          "n_segments_Silver",
          "n_segments_Bronze",
          "n_damaging_variants_in_parent",
          "n_damaging_variants_transmitted",
          "n_damaging_variants_resolved",
          "n_damaging_variants_unresolved",
          "n_genes_het_masked",
          "n_genes_hom_exposed_same_variant",
          "n_genes_compound_het_trans",
          "n_genes_compound_het_cis",
          "n_genes_partially_resolved",
          "mendelian_consistency_status",
          "mendelian_inconsistent_sites",
          "damaging_tier"
        ]
      }
    },
    "types": {
      "dyad_id":                            {"type": "string"},
      "parent_sample_id":                   {"type": "string"},
      "offspring_sample_id":                {"type": "string"},
      "n_segments_total":                   {"type": "integer", "minimum": 0},
      "n_segments_Gold":                    {"type": "integer", "minimum": 0},
      "n_segments_Silver":                  {"type": "integer", "minimum": 0},
      "n_segments_Bronze":                  {"type": "integer", "minimum": 0},
      "n_damaging_variants_in_parent":      {"type": "integer", "minimum": 0},
      "n_damaging_variants_transmitted":    {"type": "integer", "minimum": 0},
      "n_damaging_variants_resolved":       {"type": "integer", "minimum": 0},
      "n_damaging_variants_unresolved":     {"type": "integer", "minimum": 0},
      "n_genes_het_masked":                 {"type": "integer", "minimum": 0},
      "n_genes_hom_exposed_same_variant":   {"type": "integer", "minimum": 0},
      "n_genes_compound_het_trans":         {"type": "integer", "minimum": 0},
      "n_genes_compound_het_cis":           {"type": "integer", "minimum": 0},
      "n_genes_partially_resolved":         {"type": "integer", "minimum": 0},
      "mendelian_consistency_status":       {"enum": ["pass", "warn", "fail", "untestable"], "description": "dyads only ever reach 'untestable' for the full test; pass/warn/fail apply to the parent-hom subset"},
      "mendelian_inconsistent_sites":       {"type": "integer", "minimum": 0},
      "damaging_tier":                      {"enum": ["T1", "T2", "T3"]}
    }
  }
}
